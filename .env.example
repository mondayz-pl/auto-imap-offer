# === PANEL ADMINA ===
# Hasło do panelu pod oferty.turystycznezacisze.pl/login
# Jeśli nie ustawione, przy starcie zostanie wylosowane i wypisane w logach (docker compose logs)
ADMIN_PASSWORD=zmien-to-haslo

# === AI PROVIDER ===
# Wybierz dostawcę: anthropic (domyślnie) lub openai
AI_PROVIDER=anthropic

# === ANTHROPIC ===
ANTHROPIC_API_KEY=sk-ant-...
# Opcjonalnie — nadpisz domyślne modele:
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_QUALITY=claude-sonnet-5

# === OPENAI (tylko gdy AI_PROVIDER=openai) ===
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_QUALITY=gpt-4o

# === IMAP (skrzynka klienta na wp.pl lub inny serwer) ===
IMAP_HOST=imap.wp.pl
IMAP_PORT=993
IMAP_USER=biuro@twojadomena.pl
IMAP_PASSWORD=haslo_do_skrzynki

# Dokładna nazwa folderu Wersje robocze widoczna w kliencie pocztowym.
# Outlook z kontem IMAP: zazwyczaj "Wersje robocze". Thunderbird/webmail: może być "Drafts".
IMAP_DRAFTS_FOLDER=Wersje robocze

# === BIZNES ===
# Krótki opis firmy wstrzykiwany do promptów klasyfikacji i ekstrakcji.
# Od tego zależy, co bot uzna za "zapytanie ofertowe" - opisz konkretnie,
# co firma świadczy.
BUSINESS_DESCRIPTION=pensjonat "W Zaciszu" - noclegi (pokoje i apartamenty ze śniadaniem), SPA (sauna, jacuzzi, masaże), sala konferencyjna, przyjęcia weselne, atrakcje (przejażdżki bryczką, rowery, chata grillowa)

# === DANE FIRMY (do podpisu w ofercie) ===
COMPANY_NAME=W Zaciszu
# "\n" w podpisie zostanie zamienione na nową linię
COMPANY_SIGNATURE=Recepcja W Zaciszu\ntel. +48 600 000 000\nwww.wzaciszy.pl

# === BOT ===
# Jak często sprawdzać skrzynkę (minuty)
POLL_INTERVAL_MINUTES=3

# Maksymalna liczba maili obsługiwanych w jednym cyklu (bezpiecznik kosztowy)
MAX_EMAILS_PER_CYCLE=10

# Po ilu nieudanych próbach porzucić mail (trafia wtedy do logów jako "porzucam")
MAX_ATTEMPTS_PER_EMAIL=3

# Custom flaga IMAP oznaczająca już przetworzone maile - nie zmieniaj po starcie produkcyjnym
PROCESSED_FLAG=AI-Processed

# Lokalny rejestr przetworzonych maili (autorytatywny; flaga IMAP to tylko dodatek)
PROCESSED_STORE_PATH=./data/processed-store.json

# Ścieżka do cennika CSV (domyślnie ./data/cennik.csv)
PRICING_CSV_PATH=./data/cennik.csv

# Opcjonalny plik z zasadami cennika (sezonowość, wyjątki, uwagi dla AI)
PRICING_NOTES_PATH=./data/cennik-uwagi.txt

# === STATUS SERVER ===
# Port wewnętrzny kontenera (Traefik forwarduje ruch z domeny na ten port)
STATUS_PORT=3000

# === LOGI ===
# Poziom logowania: trace | debug | info | warn | error
LOG_LEVEL=info
